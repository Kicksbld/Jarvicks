// ---- WiFi (l'ESP32 et ton Mac doivent etre sur le MEME reseau 2.4 GHz) ----
#define WIFI_SSID "TON_RESEAU_WIFI"
#define WIFI_PASS "TON_MOT_DE_PASSE"

// ---- Reseau ----
#define MDNS_HOSTNAME "jarvicks"   // -> http://jarvicks.local/
#define HTTP_PORT     80

// ---- Camera ----
// Resolutions possibles : FRAMESIZE_QVGA (320x240), FRAMESIZE_VGA (640x480),
//                         FRAMESIZE_SVGA (800x600), FRAMESIZE_XGA (1024x768)...
#define CAMERA_FRAME_SIZE   FRAMESIZE_VGA
#define CAMERA_JPEG_QUALITY 12   // 10 = meilleure qualite ... 63 = la pire
